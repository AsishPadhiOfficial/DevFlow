{
  "title": "DevFlow Dashboard",
  "panels": [
    {
      "type": "timeseries",
      "title": "HTTP Requests per Second",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[1m])) by (job)",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP Request Duration p99",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, job))",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Total Requests Count",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(http_requests_total) by (job)",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Active WebSocket Connections",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 8 },
      "targets": [
        {
          "expr": "sum(websockets_active) or vector(0)",
          "legendFormat": "Connections"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP Error Rate 4xx+5xx",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status=~\"[45].*\"}[1m])) by (job)",
          "legendFormat": "{{job}}"
        }
      ]
    }
  ]
}
